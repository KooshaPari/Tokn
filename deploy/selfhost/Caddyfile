{$HOSTNAME} {
	header Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
	header X-Content-Type-Options "nosniff"
	header X-Frame-Options "DENY"
	header X-XSS-Protection "1; mode=block"
	header Referrer-Policy "strict-origin-when-cross-origin"
	header Permissions-Policy "geolocation=(), microphone=(), camera=()"
	header Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https:; frame-ancestors 'none'"

	handle /status {
		respond "Tokenledger CLI self-hosted instance running. No HTTP API available. Use CLI directly." 200
	}

	handle /health {
		respond "ok" 200
	}

	handle {
		respond `<!DOCTYPE html>
<html>
<head><title>Tokenledger Self-Hosted</title></head>
<body>
<h1>Tokenledger Self-Hosted Instance</h1>
<p><strong>Tokenledger is a CLI tool</strong> with no built-in HTTP server. This instance provides data storage for usage/cost analytics.</p>
<p><strong>Data location:</strong> /data</p>
<p>Run CLI commands via: docker compose exec tokenledger-cli tokenledger <command></p>
<p>Available commands: monthly, daily, coverage, pricing-check, pricing-apply, ingest, bench, etc.</p>
</body>
</html>` 200 {
			header Content-Type text/html
		}
	}

	log {
		output stdout
		format json
	}
}

localhost:8081 {
	respond `Tokenledger CLI instance (local). No HTTP API.` 200
}
